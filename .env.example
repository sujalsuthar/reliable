# Admin panel — set in .env.local locally; Vercel dashboard in production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password
ADMIN_SESSION_SECRET=change_me_to_a_random_string_at_least_32_chars

# Public site URL (SEO, sitemap, Open Graph) — no trailing slash
SITE_URL=https://engineering.reliablecompany.sa

# CMS persistence (Vercel production — link Storage in Vercel dashboard)
# KV: Upstash Redis — auto-injected when linked to the project
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Alternative names when using Upstash directly:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Blob: auto-injected when Vercel Blob store is linked
BLOB_READ_WRITE_TOKEN=

# Optional: AI translation in CMS (falls back to MyMemory API if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
